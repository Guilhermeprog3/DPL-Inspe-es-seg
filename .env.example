# =============================================
# SIGS — Sistema de Gestão de Segurança
# Copie este arquivo para .env.local e preencha
# =============================================

# --- Banco de Dados (Supabase / PostgreSQL) ---
DATABASE_URL="postgres://user:password@host:5432/sigs"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_chave_anon_aqui"
SUPABASE_SERVICE_ROLE_KEY="sua_chave_privada_aqui"

# --- NextAuth ---
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- SMTP (Recuperação de Senha) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@email.com"
SMTP_PASS="sua_senha_de_app"
SMTP_FROM="SIGS <noreply@empresa.com.br>"

# --- App ---
NEXT_PUBLIC_APP_NAME="SIGS"
NEXT_PUBLIC_AVAILABLE_STATES="PI,MA"
NEXT_PUBLIC_API_TIMEOUT="5000"
