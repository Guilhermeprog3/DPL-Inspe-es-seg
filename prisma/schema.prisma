generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id        String   @id @default(uuid())
  nome      String
  sobrenome String
  email     String   @unique
  uf        String   // 'PI' | 'MA'
  regional  String
  role      String   // 'admin' | 'inspetor' | 'sesmt' | 'rh'
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  inspecoes Inspecao[]
}

model Equipamento {
  id                  String   @id @default(uuid())
  uuid                String   @unique @default(uuid())
  codigo              String   @unique
  codigoGalao         String?
  tipo                String
  carga               String?
  agente              String?
  numeroSerieCilindro String?
  capacidade          String
  pontoInstalacao     String
  base                String
  fabricacao          String
  proximaInspecao     String
  uf                  String
  regional            String
  status              String   // 'ativo' | 'manutencao' | 'vencido'
  inspecoes           Inspecao[]
}

model Inspecao {
  id                String   @id @default(uuid())
  equipamentoId     String
  equipamento       Equipamento @relation(fields: [equipamentoId], references: [id])
  inspetorId        String
  inspetor          User     @relation(fields: [inspetorId], references: [id])
  data              DateTime @default(now())
  status            String   
  latitude          Float?
  longitude         Float?
  observacoes       String?  @db.NVarChar(MAX)
  uf                String
  regional          String
  respostas         String   @db.NVarChar(MAX) // Armazenaremos o array de respostas como String JSON
}